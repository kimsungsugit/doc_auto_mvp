# OpenAI (AI-first 추출 + Vision OCR)
# 실제 키는 .env에만 넣고 절대 커밋하지 마세요 (.gitignore로 제외됨).
OPENAI_STRUCTURING_ENABLED=true
OPENAI_API_KEY=sk-proj-여기에_실제_키
OPENAI_STRUCTURING_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=3

# Vision OCR 튜닝 (선택)
VISION_CONCURRENCY=4
VISION_IMAGE_MAX_DIM=512
VISION_DETAIL=low
VISION_JPEG_QUALITY=70

# 보호 엔드포인트용 API 키 (/logs, /download, /ai-accuracy, /ai-cache-stats)
# 생성 예: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# 업로드/RateLimit/CORS
MAX_UPLOAD_SIZE=52428800
RATE_LIMIT_ENABLED=1
# 프로덕션에선 특정 도메인으로 제한 — "*" 금지
CORS_ORIGINS=http://localhost:8000

# 신뢰도 라우팅 임계값 오버라이드 (선택)
# CONFIDENCE_AUTO_APPROVE=0.95
# CONFIDENCE_REVIEW_NORMAL=0.80

# AI 응답 캐시
AI_CACHE_ENABLED=1
AI_CACHE_MAX_ENTRIES=2000

# OCR fallback (Vision 불가 시)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# GHOSTSCRIPT_CMD=C:\Program Files\gs\gs10.05.1\bin\gswin64c.exe
# TESSDATA_PREFIX=C:\Program Files\Tesseract-OCR\tessdata
